KRUTRIM_CLOUD_API_KEY=your_krutrim_api_key_here

# Email Configuration (SMTP)
# To send actual emails, provide your email and an App Password (not your real password).
# For Gmail: 
# 1. Turn on 2-Step Verification in your Google Account.
# 2. Go to Security -> 2-Step Verification -> App passwords.
# 3. Create a new App password and paste it below.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Firebase Configuration (for admin operations if needed)
FIREBASE_PROJECT_ID=your_firebase_project_id_here
SERPAPI_API_KEY=your_serpapi_api_key_here